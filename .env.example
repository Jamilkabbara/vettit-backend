# ============================================
# VETT BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=https://www.vettit.ai

# Supabase (get from supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anthropic / Claude AI (console.anthropic.com)
# Models used: claude-haiku-4-5 (personas + response sim + light chat)
#              claude-sonnet-4-6 (survey gen, insights, results chat)
#              claude-opus-4-7   (enterprise tier only)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe (dashboard.stripe.com → Developers → API Keys)
STRIPE_SECRET_KEY=sk_live_your-stripe-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Resend Email (resend.com → API Keys). Domain must be verified to send from @vettit.ai
RESEND_API_KEY=re_your-resend-key-here
FROM_EMAIL=hello@vettit.ai
FROM_NAME=VETT

# Admin (admin dashboard access is gated to this email)
ADMIN_EMAIL=kabbarajamil@gmail.com

# Supabase Storage bucket for creative uploads (public bucket)
STORAGE_BUCKET=vettit-uploads
