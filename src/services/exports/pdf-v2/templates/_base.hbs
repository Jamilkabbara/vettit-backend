<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{mission.title}} — VETT Report</title>
  <style>{{{fontFaceCss}}}</style>
  <style>{{{baseCss}}}</style>
</head>
<body>

  {{!-- ─── COVER (shared across all mission types) ─────────────────── --}}
  <section class="page cover">
    <div class="cover-glow"></div>

    <div class="cover-header">
      <div class="wordmark">VETT</div>
      <div class="cover-tagline">AI-Powered Market Research</div>
    </div>

    <div class="cover-title-block">
      <h1 class="cover-title">{{mission.title}}</h1>
      {{#if mission.brief}}
      <p class="cover-brief">{{mission.brief}}</p>
      {{/if}}

      <div class="cover-meta">
        <div class="cover-meta-key">Respondents</div>
        <div class="cover-meta-val">{{mission.respondent_count}}</div>
        <div class="cover-meta-key">Mission completed</div>
        <div class="cover-meta-val">{{missionCompletedLabel}}</div>
        <div class="cover-meta-key">Report generated</div>
        <div class="cover-meta-val">{{reportGeneratedLabel}}</div>
        <div class="cover-meta-key">Mission ID</div>
        <div class="cover-meta-val">{{mission.id}}</div>
      </div>
    </div>

    <div class="cover-footer">
      Generated by VETT · vettit.ai
    </div>
  </section>

  {{!-- ─── BODY (mission-type specific) ────────────────────────────── --}}
  {{> body}}

</body>
</html>
